VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key

# Repo wspolnik-demo: true = cała aplikacja w mockach (Supabase, FastAPI, kontakt); bez prawdziwej sieci.
# Przy false + uzupełnione VITE_SUPABASE_* — zachowanie jak produkcja (prawdziwe API).
VITE_PUBLIC_DEMO_ROUTES=true

# Domyślnie NIE ustawiaj na produkcji. Tylko true = możliwy prawdziwy Supabase/API (np. lokalny test z gabi-site).
# W Vitest ustawiane automatycznie. Bez tego: zawsze mocki — nic nie trafia do bazy.
# VITE_DEMO_ALLOW_REAL_BACKEND=true
