{
  "buildCommand": "cd site && npm run build",
  "outputDirectory": "site/dist",
  "rewrites": [
    { "source": "/api/(.*)", "destination": "/api/index.py" },
    { "source": "/((?!api/).*)", "destination": "/site/dist/index.html" }
  ],
  "crons": [
    {
      "path": "/api/charges/cron",
      "schedule": "0 6 * * *"
    }
  ]
}
